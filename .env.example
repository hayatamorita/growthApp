# Local Docker Compose database
DATABASE_URL=postgresql://user:password@db:5432/growth
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=growth

# Production database example
# PRODUCTION_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Flask secret key
FLASK_SECRET_KEY=change-me

# Optional upload limits
MAX_IMAGE_BYTES=10485760
MAX_UPLOAD_BYTES=11534336
